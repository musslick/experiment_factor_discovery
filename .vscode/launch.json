{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Diagnose Synthesis",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/diagnose_synthesis.py",
            "args": ["--factor", "congruency"],
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal"
        },
        {
            "name": "Test LLM (smoke test)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run_llm_test.py",
            "args": ["--model", "claude-sonnet-4-6"],
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal"
        },
        {
            "name": "Test LLM (pytest suite)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["tests/test_llm_integration.py", "-v", "-m", "integration"],
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal"
        },
        {
            "name": "Run Benchmark",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run_benchmark.py",
            "args": ["--config", "config/benchmark.yaml"],
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal"
        },
        {
            "name": "Run Discovery",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run_discovery.py",
            "args": ["--config", "config/discovery.yaml"],
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal"
        },
        {
            "name": "Generate Data",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/generate_data.py",
            "args": ["--config", "config/benchmark.yaml"],
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal"
        },
        {
            "name": "Produce Results: Synthetic (all benchmarks)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/produce_results_synthetic.py",
            "args": ["--config", "config/produce_synthetic.yaml"],
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal"
        },
        {
            "name": "Produce Results: Synthetic (quick test, 1 run)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/produce_results_synthetic.py",
            "args": [
                "--config", "config/produce_synthetic.yaml",
                "--n-runs", "5",
                "--benchmarks", "stroop_simon"
            ],
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal"
        },
        {
            "name": "Produce Results: Empirical (benchmark + discovery)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/produce_results_empirical.py",
            "args": ["--config", "config/produce_empirical.yaml"],
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal"
        },
        {
            "name": "Produce Results: Empirical (benchmark only)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/produce_results_empirical.py",
            "args": ["--config", "config/produce_empirical.yaml", "--skip-discovery"],
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal"
        },
        {
            "name": "Produce Results: Empirical (discovery only)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/produce_results_empirical.py",
            "args": ["--config", "config/produce_empirical.yaml", "--skip-benchmark"],
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal"
        },
        {
            "name": "Make Figures: Synthetic (Figure 2)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/plots/make_figures_synthetic.py",
            "args": [
                "--results", "results/aggregated/synthetic_results.json",
                "--output-dir", "plots/output"
            ],
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal"
        },
        {
            "name": "Make Figures: Empirical (Figures 3 + 4)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/plots/make_figures_empirical.py",
            "args": [
                "--results", "results/aggregated/empirical_results.json",
                "--synthetic-results", "results/aggregated/synthetic_results.json",
                "--output-dir", "plots/output"
            ],
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal"
        }
    ]
}